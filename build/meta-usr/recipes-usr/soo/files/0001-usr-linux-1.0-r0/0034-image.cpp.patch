+#include "image.hpp"
+
+namespace emiso {
+
+    namespace image {
+
+        ImageApi::ImageApi(httpserver::webserver *server, Daemon *daemon)
+            : _server(server) {
+                std::string path  = "/images";
+
+            // Create routes and handlers
+            _listHandler    = new ListHandler(daemon);
+            _historyHandler = new HistoryHandler(daemon);
+            _inspectHandler = new InspectHandler(daemon);
+
+            _server->register_resource(path + "/json", _listHandler);
+            _server->register_resource("/v[1-9]+.[0-9]+" + path + "/json", _listHandler);
+
+            _server->register_resource(path + "/{[a-zA-Z0-9_-]+}/history", _listHandler);
+            _server->register_resource("/v[1-9]+.[0-9]+" + path + "/{[a-zA-Z0-9_-]+}/history", _listHandler);
+
+            _server->register_resource(path + "/{[a-zA-Z0-9_-]+}/json", _inspectHandler);
+            _server->register_resource("/v[1-9]+.[0-9]+" + path + "/{[a-zA-Z0-9_-]+}/json", _inspectHandler);
+        }
+
+        ImageApi::~ImageApi() {}
+    }
+}
